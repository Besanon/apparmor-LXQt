abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/startlxqtwayland
@{att} = /att/startlxqtwayland/
profile startlxqtwayland /{,usr/}bin/startlxqtwayland {
  include <abstractions/attached/base>
  include <abstractions/attached/consoles>
  include <abstractions/lxqt>
  include <abstractions/attached/nameservice-strict>

  signal (receive) set=(term) peer=sddm,

  @{exec_path} mr,

  @{bin}/cat rix,
  @{bin}/cut rix,
  @{bin}/cp  rix,
  @{bin}/dirname rix,
  @{bin}/labwc  rPx,
  @{bin}/wayfire  rPx,
  @{bin}/kwin_wayland  rPx,
  @{bin}/{,e}grep rix,
  @{bin}/{m,g,}awk rix,
  @{bin}/mkdir		    rix,
  @{sh_path}		    rix,
  @{bin}/lxqt-session 	    rPx,
  @{bin}/kwin_wayland_wrapper rPx,
  @{bin}/systemd-detect-virt rPx,
  @{bin}/systemctl                           rCx -> systemctl,
  @{bin}/tr		    rix, 
  @{bin}/sed		    rix, 
  @{bin}/dbus-update-activation-environment  rCx -> dbus,

  /usr/share/color-schemes/{,**} r,
  /usr/share/desktop-directories/{,**} r,
  /usr/share/icu/@{int}.@{int}/*.dat r,
  /usr/share/kservices5/{,**} r,
  /usr/share/mime/{,**} r,

  /etc/locale.alias r,
  /etc/machine-id r,
  /etc/xdg/menus/{,**} r,

  @{HOME}/ r,
  owner @{HOME}/.Xauthority r,

  owner @{user_cache_dirs}/ rw,
  owner @{user_cache_dirs}/#@{int} rw,
        @{user_cache_dirs}/ksycoca5_* rwkl -> @{user_cache_dirs}/#@{int},

  owner @{user_config_dirs}/#@{int} rw,
  owner @{user_config_dirs}/labwc/ rw,
  owner @{user_config_dirs}/labwc/** rw,
  owner @{user_config_dirs}/lxqt/ rw,
  owner @{user_config_dirs}/menus/{,**} r,
  owner @{user_config_dirs}/lxqt/wayland/ rw,
  owner @{user_config_dirs}/lxqt/wayland/lxqt-wayfire.ini rw,
  owner @{user_config_dirs}/kxkbrc rw,         # NNNN

  owner @{user_share_dirs}/kservices5/{,**} r,
  owner @{user_share_dirs}/sddm/wayland-session.log rw,
  owner @{user_share_dirs}/sddm/xorg-session.log rw,

  owner /tmp/#@{int} rw,
  owner /tmp/startlxqt.@{rand6} rwl -> /tmp/#@{int},

  owner @{run}/user/@{uid}/ r,

        @{PROC}/sys/kernel/core_pattern r,

  /dev/tty rw,
  /dev/tty@{u8} rw,

  profile systemctl flags=(attach_disconnected, attach_disconnected.path=@{att}) {
    include <abstractions/attached/base>
    include <abstractions/app/systemctl>

    owner @{user_share_dirs}/sddm/wayland-session.log w,
  
    include if exists <local/startlxqt_systemctl>
  }

  profile dbus {
    include <abstractions/attached/base>

    @{bin}/dbus-update-activation-environment mr,

    signal (send) set=(kill, term)  peer=dbus-daemon,

    /var/lib/dbus/machine-id r,

    owner @{HOME}/.xsession-errors w,

    owner @{user_share_dirs}/sddm/wayland-session.log w,

    owner @{PROC}/@{pid}/fd/ r,

    /dev/tty@{u8} rw,

    include if exists <local/startlxqt_dbus>
  }

  include if exists <local/startlxqtwayland>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
