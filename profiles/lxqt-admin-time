abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-admin-time 
@{att} = ""
profile lxqt-admin-time /{,usr/}bin/lxqt-admin-time {
  include <abstractions/base-strict>
  include <abstractions/lxqt>
  include <abstractions/bus-accessibility>
  include <abstractions/nameservice-strict>

  ptrace read peer=lxqt-admin-time,  

  @{exec_path}			mr,
  
  @{bin}/lxqt-admin-time-helper		rPx,
  @{bin}/pkexec                     Cx -> pkexec,

  /etc/timezone r,

  owner @{user_config_dirs}/lxqt/#@{int} rwk,
  owner @{user_config_dirs}/lxqt/TimeDate.conf rwkl -> @{user_config_dirs}/lxqt/#@{int},
  owner @{user_config_dirs}/lxqt/TimeDate.conf.lock rwk,
  owner /tmp/@{int}  		       r,

  /dev/tty				rw,

  profile pkexec {
    include <abstractions/base-strict>
    include <abstractions/app/pkexec>

    @{bin}/lxqt-admin-time-helper rPx,

    @{PROC}/@{pid}/mounts r,

    include if exists <local/lxqt-admin-time_pkexec>
  }


  include if exists <local/lxqt-admin-time>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
