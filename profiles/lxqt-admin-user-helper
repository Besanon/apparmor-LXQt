abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-admin-user-helper
@{att} = ""
profile lxqt-admin-user-helper /{,usr/}bin/lxqt-admin-user-helper {
  include <abstractions/base-strict>
  include <abstractions/bus-accessibility>
  include <abstractions/lxqt>
    
  @{exec_path}		mr,

  @{bin}/gpasswd 		rPx,
  @{bin}/passwd 		rPx,
  @{bin}/useradd		rPx,
  @{bin}/userdel		rPx,
  @{bin}/passwd 		rPx,
  @{sbin}/usermod 		rPx,
  
  owner @{sh_path} 		r,
  owner /tmp/@{int}  		r,

  /dev/tty			rw,

  include if exists <local/lxqt-admin-user-helper>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
