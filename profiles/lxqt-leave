abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-leave
@{att} = ""
profile lxqt-leave /{,usr/}bin/lxqt-leave {
  include <abstractions/base-strict>
  include <abstractions/lxqt>

  @{exec_path} mr,

  owner @{user_config_dirs}/lxqt/power.conf rw,

  owner /tmp/@{int} r,

  /dev/tty rw,
  owner /dev/tty@{u16} rw,

  include if exists <local/lxqt-leave>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
