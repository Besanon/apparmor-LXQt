abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-admin-user
@{att} = ""
profile lxqt-admin-user /{,usr/}bin/lxqt-admin-user {
  include <abstractions/base-strict>
  include <abstractions/lxqt>
  include <abstractions/bus-accessibility>
  include <abstractions/nameservice-strict>

  @{exec_path}			mr,

  @{bin}/pkexec				Cx -> pkexec,

  /etc/shells 				r,

  owner /tmp/@{int}             	r,

  /dev/tty				rw,

  profile pkexec {
    include <abstractions/base-strict>
    include <abstractions/app/pkexec>

    ptrace read peer=lxqt-admin-user,

    @{bin}/lxqt-admin-user-helper	rPx,

    @{PROC}/@{pid}/cgroup r,

    include if exists <local/lxqt-admin-user_pkexec>
  }


  include if exists <local/lxqt-admin-user>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
