abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-config-powermanagement
@{att} = ""
profile lxqt-config-powermanagement /{,usr/}bin/lxqt-config-powermanagement {
  include <abstractions/base-strict>
  include <abstractions/backlight>
  include <abstractions/lxqt>
  include <abstractions/nameservice-strict>

  @{exec_path} mr,

  owner @{user_config_dirs}/lxqt/#@{int} rw,
  owner @{user_config_dirs}/lxqt/power.conf rw,
  owner @{user_config_dirs}/lxqt/power.conf.lock rwk,
  owner @{user_config_dirs}/lxqt/power.conf.@{rand6} rw,
  owner @{user_config_dirs}/lxqt/power.conf.@{rand6} l -> @{user_config_dirs}/lxqt/#@{int},
  owner @{user_config_dirs}/lxqt/lxqt-powermanagement.conf rw,
  owner @{user_config_dirs}/lxqt/lxqt-powermanagement.conf.lock rwk,
  owner @{user_config_dirs}/lxqt/lxqt-powermanagement.conf.@{rand6} rw,
  owner @{user_config_dirs}/lxqt/lxqt-powermanagement.conf.@{rand6} l -> @{user_config_dirs}/lxqt/#@{int},

  @{sys}/devices/@{pci}/drm/card1/card1-eDP-1/intel_backlight/bl_power rw,

  owner /tmp/@{int} r,

  /dev/tty rw,

  include if exists <local/lxqt-config-powermanagement>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
