abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-session
@{att} = /att/lxqt-session/
profile lxqt-session /{,usr/}bin/lxqt-session flags=(attach_disconnected, attach_disconnected.path=@{att}) {
  include <abstractions/attached/base>
  include <abstractions/app-launcher-user>
  include <abstractions/dconf>
  include <abstractions/lxqt>
  include <abstractions/qt5-shader-cache>
  include <abstractions/attached/nameservice-strict>

  network netlink raw,

  signal (send),
  signal (receive) set=(kill, term) peer=kwin_wayland,
  signal (receive) set=(kill, term) peer=startlxqt,
  signal (receive) set=(kill, term) peer=sddm,

  @{exec_path} mr,

  @{sh_path}                          Cx -> shell,
  @{bin}/sed                          rix,
  @{bin}/readlink                     rix,
  @{bin}/dirname                      rix,
  @{bin}/system-config-printer-applet rPx,
  @{bin}/dbus-update-activation-environment rCx -> dbus,
  @{bin}/systemctl                    rCx -> systemctl,

  @{bin}/pavucontrol                  rPx,
  @{lib}/geoclue-2.0/demos/agent      rPx,
  @{bin}/nm-connection-editor         rPx,
  @{bin}/nm-applet                    rPx,
  @{bin}/dconf-editor                 rPx,
  @{bin}/setxkbmap                    rPx,
  @{bin}/start-pulseaudio-x11         rPx,
  @{bin}/xrdb                         rPx,
  @{bin}/xdg-user-dirs-update         rPx,

  /usr/share/                         r,
  /usr/share/cursors/                 r,
  /usr/share/backintime/common/*      r,
  /usr/share/desktop-directories/*    r,
  /usr/share/system-config-printer/*  r,

  /etc/xdg/                           r,
  /etc/xdg/autostart/                 r,
  /etc/xdg/autostart/*.desktop        r,
  /etc/xdg/menus/lxqt-*               r,
  /etc/xdg/openbox/*                  r,
  /etc/udev/udev.conf                 r,

  owner @{user_config_dirs}/autostart/ r,
  owner @{user_config_dirs}/autostart/*.desktop r,
  owner @{user_cache_dirs}/openbox/   rw,
  owner @{user_cache_dirs}/openbox/sessions/          rw,
  owner @{user_cache_dirs}/openbox/openbox.log        rwk,
  owner @{user_config_dirs}/mimeapps.list{,.@{rand6}} rw,
  owner @{user_config_dirs}/openbox/rc.xml            r,
  owner @{user_config_dirs}/lxqt/lxqt.conf.lock rwk,
  owner @{user_config_dirs}/lxqt/*.conf rw,

  @{att}@{run}/systemd/inhibit/@{int}.ref rw,
  owner @{att}/dev/tty@{u16} rw,

  @{PROC}/                             r,
  @{PROC}/uptime                       r,
  @{PROC}/@{pid}/stat                  r,
  owner @{PROC}/@{pid}/ 	       r,
  owner @{PROC}/@{pid}/stat            r,

  /dev/tty                             rw,
  /dev/tty@{u16}                       rw,
  owner /dev/tty@{u16} rw,

  deny ptrace,

  profile shell {
    include <abstractions/base-strict>

    owner @{user_share_dirs}/sddm/xorg-session.log w,
    owner @{user_share_dirs}/sddm/wayland-session.log w,

    /dev/tty                                            rw,
    /dev/tty@{u16}                                      rw,
    /dev/pts/@{u16}                                     rw,

    @{sh_path}                                          mr,

  }

  profile systemctl {
    include <abstractions/attached/base>
    include <abstractions/app/systemctl>

    include if exists <local/lxqt-session_systemctl>
  }

  profile dbus flags=(attach_disconnected) {
    include <abstractions/attached/base>
    include <abstractions/bus-session>

    @{bin}/dbus-update-activation-environment mr,

    owner /dev/tty@{u16} rw,
    /dev/tty@{u16} rw,

    include if exists <local/lxqt-session_dbus>
  }

  include if exists <local/lxqt-session>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
