abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-config-brightness
@{att} = ""
profile lxqt-config-brightness /{,usr/}bin/lxqt-config-brightness {
  include <abstractions/base-strict>
  include <abstractions/lxqt>

  signal (send)  set=term peer=lxqt-config-brightness//pkexec,

  @{exec_path} mr,

  @{bin}/pkexec Cx -> pkexec,

  @{sh_path} Cx -> shell,

  owner @{HOME}/ r,

  owner /tmp/@{int} r,

  @{sys}/class/backlight/ r,
  @{sys}/devices/@{pci}/*_backlight/{,max_,actual_}brightness rw,
  @{sys}/devices/@{pci}/*_backlight/{uevent,type,enabled} r,
  @{sys}/devices/@{pci}/backlight/**/{,max_,actual_}brightness rw,
  @{sys}/devices/@{pci}/backlight/**/{uevent,type,enabled} r,
  @{sys}/devices/@{pci}/backlight/**/brightness rw,
  @{sys}/devices/@{pci}/drm/card1/card1-eDP-1/intel_backlight/bl_power r,
  @{sys}/devices/@{pci}/drm/card1/card1-LVDS-1/intel_backlight/bl_power r,

  /dev/tty rw,

  profile pkexec {
    include <abstractions/base-strict>
    include <abstractions/app/pkexec>

    signal (receive)  set=term peer=lxqt-config-brightness,

    @{bin}/@{bin}/lxqt-config-brightness px,
    @{bin}/lxqt-backlight_backend px,

    @{etc_ro}/inputrc r,
    @{etc_ro}/inputrc.keys r,

    @{user_share_dirs}/sddm/wayland-session.log w,
    @{user_share_dirs}/sddm/xorg-session.log w,

    @{sys}/class/backlight/ r,
    @{sys}/devices/@{pci}/*_backlight/{,max_,actual_}brightness rw,
    @{sys}/devices/@{pci}/*_backlight/{uevent,type,enabled} r,
    @{sys}/devices/@{pci}/backlight/**/{,max_,actual_}brightness rw,
    @{sys}/devices/@{pci}/backlight/**/{uevent,type,enabled} r,
    @{sys}/devices/@{pci}/backlight/**/brightness rw,

    include if exists <local/lxqt-config-brightness_pkexec>
  }

  profile shell {
    include <abstractions/base-strict>

    @{sh_path}                                          mr,
    @{bin}/pkexec rPx,

    owner @{user_share_dirs}/sddm/xorg-session.log w,
    owner @{user_share_dirs}/sddm/wayland-session.log w,

    /dev/tty                                            rw,
    /dev/tty@{u16}                                      rw,
    /dev/pts/@{u16}                                     rw,

  }

  include if exists <local/lxqt-config-brightness>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
