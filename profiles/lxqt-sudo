abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-sudo 
@{att} = /att/lxqt-sudo/
profile lxqt-sudo /{,usr/}bin/lxqt-sudo flags=(attach_disconnected, attach_disconnected.path=@{att}) {
  include <abstractions/attached/base>
  include <abstractions/attached/consoles>
  include <abstractions/lxqt>
  include <abstractions/bus-accessibility>

  signal (send) set=(int,kill) peer=lxqt-sudo//sudo,

  @{exec_path}				mr,

  @{bin}/sudo rCx -> root,

  owner /tmp/@{int}  				r,

  /dev/tty					rw,
  /dev/pts/@{u8} 				rwk,
  /dev/ptmx rw,

  profile root {
    include <abstractions/base-strict>
    include <abstractions/app/sudo>

    @{bin}/lsblk rPx,

    include if exists <local/lxqt-sudo_root>
  }

  include if exists <local/lxqt-sudo>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
