abi <abi/4.0>,

include <tunables/global>

@{exec_path} = @{bin}/lxqt-archiver
@{att} = /
profile lxqt-archiver /{,usr/}bin/lxqt-archiver flags=(attach_disconnected, attach_disconnected.path=@{att}) {
  include <abstractions/base-strict>
  include <abstractions/bus-accessibility>
  include <abstractions/lxqt>
  include <abstractions/nameservice-strict>
  include <abstractions/thumbnails-cache-read>
  include <abstractions/thumbnails-cache-write>
  include <abstractions/user-read-strict>
  include <abstractions/user-write-strict>
  
  @{exec_path}		mr,

  @{bin}/mv  rix,
  @{bin}/rm  rix,
  @{bin}/tar			rix,
  @{bin}/unzip			rix,
  @{bin}/7z 			rix,
  @{lib}/7zip/7z rix,

  /usr/share/lxqt-archiver/translations/lxqt-archiver_de.qm r,
  /usr/share/libfm-qt6/translations/libfm-qt_de.qm r,
  /usr/share/thumbnailers/ 	 r,
  /usr/share/thumbnailers/*	 r,
  
  /etc/fstab 			 r,

  owner @{HOME}/ 		 r,

  owner @{user_config_dirs}/lxqt/#@{int} rwk,
  owner @{user_config_dirs}/lxqt/archiver.conf rw,
  owner @{user_config_dirs}/lxqt/archiver.conf.lock rwk,
  owner @{user_config_dirs}/lxqt/archiver.conf l -> @{user_config_dirs}/lxqt/#@{int},

  owner @{user_cache_dirs}/.??-@{rand6}/ rw,
  owner @{user_cache_dirs}/.??-@{rand6}/file-list rw,

  owner @{PROC}/@{pid}/mountinfo r,
  owner @{PROC}/@{pid}/mounts 	 r,

  owner /tmp/@{int}  		 r,
  owner /tmp/lxqt-archiver-@{int}/ rw,

  /dev/tty			 rw,
  owner /dev/tty@{u16} rw,

  deny /usr/share/gvfs/remote-volume-monitors/ r,
  deny owner @{user_share_dirs}/gvfs-metadata/home r,
  deny @{HOME}/.* r,

  include if exists <local/lxqt-archiver>
}

# vim:syntax=apparmor

# vim:syntax=apparmor
